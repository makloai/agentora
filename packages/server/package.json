{
  "name": "@agentora/server",
  "version": "0.0.0",
  "description": "agentora runtime — createApp, implement, middleware, streaming. Node + edge.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makloai/agentora.git",
    "directory": "packages/server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
