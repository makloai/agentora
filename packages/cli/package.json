{
  "name": "@agentora/cli",
  "version": "0.1.0",
  "description": "CLI adapter and the agentora bin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makloai/agentora.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentora": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentora/core": "workspace:*",
    "@agentora/doctor": "workspace:*",
    "@agentora/http": "workspace:*",
    "@agentora/mcp": "workspace:*",
    "@agentora/server": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
