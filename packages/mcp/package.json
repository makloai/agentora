{
  "name": "@agentora/mcp",
  "version": "0.0.0",
  "description": "MCP server adapter for agentora apps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./oauth": "./dist/oauth.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/oauth.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentora/core": "workspace:*",
    "@agentora/server": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
